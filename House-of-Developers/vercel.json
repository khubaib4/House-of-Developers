{
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "dist/public",
  "framework": null,
  "installCommand": "npm install",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/case-studies",                             "destination": "/portfolio",             "permanent": true },

    { "source": "/checkout-2/",                              "destination": "/contact",               "permanent": true },
    { "source": "/book-a-call/",                             "destination": "/contact",               "permanent": true },
    { "source": "/book-a-call",                              "destination": "/contact",               "permanent": true },
    { "source": "/my-account-2/",                            "destination": "/contact",               "permanent": true },
    { "source": "/my-account-2",                             "destination": "/contact",               "permanent": true },
    { "source": "/contact/",                                 "destination": "/contact",               "permanent": true },

    { "source": "/portfolio/",                               "destination": "/portfolio",             "permanent": true },

    { "source": "/product/:slug/",                           "destination": "/portfolio",             "permanent": true },
    { "source": "/product/:slug",                            "destination": "/portfolio",             "permanent": true },
    { "source": "/house-of-halmar-e-commerce-marketplace/", "destination": "/portfolio",             "permanent": true },
    { "source": "/house-of-halmar-e-commerce-marketplace",  "destination": "/portfolio",             "permanent": true },

    { "source": "/service/single-service/",                  "destination": "/services",              "permanent": true },
    { "source": "/service/:slug/",                           "destination": "/services",              "permanent": true },
    { "source": "/service/:slug",                            "destination": "/services",              "permanent": true },

    { "source": "/services/ai/ai-agents",                    "destination": "/services/ai-services/ai-agents", "permanent": true },
    { "source": "/services/ai/:slug",                        "destination": "/services/ai-services/:slug",     "permanent": true },

    { "source": "/privacy-policy-2/",                        "destination": "/privacy",               "permanent": true },
    { "source": "/privacy-policy-2",                         "destination": "/privacy",               "permanent": true },

    { "source": "/team/",                                    "destination": "/about",                 "permanent": true },
    { "source": "/team",                                     "destination": "/about",                 "permanent": true },

    { "source": "/portfolio-2/portfolio-single/",             "destination": "/portfolio",             "permanent": true },
    { "source": "/portfolio-2/",                             "destination": "/portfolio",             "permanent": true },
    { "source": "/portfolio-2/:slug*",                       "destination": "/portfolio",             "permanent": true },
    { "source": "/product-tag/:slug*",                       "destination": "/portfolio",             "permanent": true },
    { "source": "/category/:slug*",                          "destination": "/",                      "permanent": true },

    { "source": "/binsro_template/:slug*",                   "destination": "/",                      "permanent": true },
    { "source": "/wp-json/:path*",                           "destination": "/",                      "permanent": true },
    { "source": "/wp-:path*",                                "destination": "/",                      "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
